#!/bin/bash
# @desc tmux ラッパー。カスタムサブコマンドを追加し、それ以外は本物の tmux に委譲する
# @usage tmux [subcommand|tmux-args...]
# @example tmux pm
# @category tmux

REAL_TMUX="/opt/homebrew/bin/tmux"

cmd_pm() {
  exec tmux-pane-manager "$@"
}

case "${1:-}" in 
  pm) shift; cmd_pm "$@" ;;
  *) exec $REAL_TMUX "$@" ;;
esac

