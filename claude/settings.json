{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "false",
    "pr": "false"
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "Bash(cd:*)",
      "Bash(cat:*)",
      "Search(*)",
      "Read(*)",
      "Fetch(*)",
      "Bash(git fetch*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -r '\"display notification \\\"\" + .message + \"\\\" with title \\\"\" + .title + \"\\\" sound name \\\"Glass\\\"\"' | xargs -I {} osascript -e '{}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"作業が完了しました。\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "claude auth whoami"
  },
  "enabledPlugins": {
    "secretary@cc-secretary": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "cc-secretary": {
      "source": {
        "source": "github",
        "repo": "Shin-sibainu/cc-secretary"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "alwaysThinkingEnabled": false,
  "general": {
    "verboseLogging": true
  },
  "autoApproveTools": [
    "Read",
    "Search"
  ],
  "feedbackSurveyState": {
    "lastShownTime": 1754039269306
  }
}
