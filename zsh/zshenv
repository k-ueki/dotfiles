# Ensure that a non-login, non-interactive shell has a defined environment.

if [ "$LS_COLORS" -a -f /etc/DIR_COLORS ]; then
  eval $(dircolors /etc/DIR_COLORS)
fi

export GOPATH=$HOME/go
export PYENV_ROOT="$HOME/.pyenv"
export Z_PATH=$HOME/dotfiles/zsh

# ---- PATH (order matters — do not rearrange) ----
export PATH="/opt/homebrew/bin:$PATH"                                          # system
export PATH="$PATH:$GOPATH/bin"                                                # lang: go
export PATH="$HOME/.nodebrew/current/bin:$PATH"                                # lang: node
export PATH="$HOME/CyberAgent/dynalyst-mgmt-fm-tool:$PATH"                    # work
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH" # lang: node

# dotfiles/bin and all subdirectories
for d in ${HOME}/dotfiles/bin ${HOME}/dotfiles/bin/*/; do
  [ -d "$d" ] && export PATH="${d%/}:${PATH}"
done

export PATH="$HOME/.jenv/shims:$PATH"                                          # lang: java
export PATH="${HOME}/.scalaenv/bin:${PATH}"                                     # lang: scala
export PATH="${PATH}:${HOME}/tools/cycloud"                                     # tools
export PATH="/opt/homebrew/opt/postgresql@13/bin:$PATH"                         # tools: pg

export PATH="${HOME}/tools/fzf-chrome-active-tab/chrome-tab-activate:$PATH"    # tools: chrome

export LSCOLORS=cxfxcxdxbxGxDxabagacad


[[ -f /Users/s11308/tools/kube-ps1/kube-ps1.sh ]] && source /Users/s11308/tools/kube-ps1/kube-ps1.sh
