export SHELL=/bin/zsh

# Reset completion state set by /etc/zshrc (nix) so zim can initialize cleanly
unset _comps

# kube-ps1 must be loaded before myconf (gitster theme uses kube_ps1 in PS1)
[[ -f ${HOME}/tools/kube-ps1/kube-ps1.sh ]] && source ${HOME}/tools/kube-ps1/kube-ps1.sh

for f in ${Z_PATH}/myconf/*; do
	if [ -d $f ]; then
		for file in $f/*; do
			source $file
		done
	fi
	if [ -f $f ]; then
		if [[ "$(basename $f)" == "tmux_conf.zsh" ]]; then
			continue
		fi
		source $f
	fi
done

source ${HOME}/tools/z/z.sh
# Load zsh-abbr after zim.zsh so it binds in viins keymap (vi mode)
source /opt/homebrew/share/zsh-abbr/zsh-abbr.zsh
eval "$(abbr-loader $HOME/dotfiles/zsh/abbr/abbr.yaml)"

source ${Z_PATH}/myconf/tmux_conf.zsh

eval "$(direnv hook zsh)"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# bun completions
[ -s "/Users/s11308/.bun/_bun" ] && source "/Users/s11308/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

alias claude-mem='/Users/s11308/.bun/bin/bun "/Users/s11308/.claude/plugins/cache/thedotmack/claude-mem/12.1.1/scripts/worker-service.cjs"'
